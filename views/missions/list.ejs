<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4">Missões</h1>
  <a href="/dashboard" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="row g-3">
  <% missions.forEach(m => { %>
    <div class="col-md-6">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title"><%= m.title %></h5>
          <p class="card-text"><%= m.description %></p>
          <span class="badge text-bg-primary">+<%= m.reward_points %> pts</span>
          <form class="mt-3" method="POST" action="/missions/offerwall/callback">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="user_id" value="<%= currentUser.id %>">
            <input type="hidden" name="mission_key" value="<%= m.key %>">
            <button type="submit" class="btn btn-success">Concluir (simulado)</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>
