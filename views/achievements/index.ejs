<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4">Conquistas</h1>
  <a href="/dashboard" class="btn btn-outline-secondary">Voltar</a>
</div>
<div class="row g-3">
  <% achievements.forEach(a => { %>
    <div class="col-md-6">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title"><%= a.title %> <span class="badge text-bg-secondary"><%= a.points %> pts</span></h5>
          <p class="card-text"><%= a.description %></p>
          <% if (a.unlocked_at) { %>
            <span class="badge text-bg-success">Desbloqueada em <%= new Date(a.unlocked_at).toLocaleDateString('pt-BR') %></span>
          <% } else { %>
            <span class="badge text-bg-warning">Bloqueada</span>
          <% } %>
        </div>
      </div>
    </div>
  <% }) %>
</div>
