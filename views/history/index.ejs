<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4">Histórico</h1>
  <a href="/dashboard" class="btn btn-outline-secondary">Voltar</a>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Missões</h5>
        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead><tr><th>Data</th><th>Missão</th><th>Status</th></tr></thead>
            <tbody>
              <% missionHistory.forEach(item => { %>
                <tr>
                  <td><%= new Date(item.created_at).toLocaleString('pt-BR') %></td>
                  <td><%= item.title %></td>
                  <td><span class="badge <%= item.status === 'completed' ? 'text-bg-success' : 'text-bg-secondary' %>"><%= item.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Saques</h5>
        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead><tr><th>Data</th><th>Valor</th><th>Banco</th><th>Status</th></tr></thead>
            <tbody>
              <% withdrawals.forEach(w => { %>
                <tr>
                  <td><%= new Date(w.created_at).toLocaleString('pt-BR') %></td>
                  <td>R$ <%= (w.amount_cents/100).toFixed(2).replace('.', ',') %></td>
                  <td><%= w.bank %></td>
                  <td><span class="badge <%= w.status === 'completed' ? 'text-bg-success' : 'text-bg-warning' %>"><%= w.status %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
